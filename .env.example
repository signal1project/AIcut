# Master AI Social — environment template. Copy to .env and fill in.
# Secrets (OAuth client secrets, AI keys) are stored at runtime via electron.safeStorage,
# not here. This file holds non-secret config and local dev pointers only.

# ─── App ───────────────────────────────────────────────
NODE_ENV=development
# Embedded API server port (0 = random free port, communicated to renderer via IPC)
API_PORT=0

# ─── AI providers (configured in-app Settings; these are dev fallbacks only) ───
# DEFAULT_AI_PROVIDER=claude        # claude | openai | groq

# ─── Platform OAuth client IDs (public; secrets go in safeStorage) ───
# FACEBOOK_CLIENT_ID=
# INSTAGRAM_CLIENT_ID=
# TWITTER_CLIENT_ID=
# THREADS_CLIENT_ID=
# PINTEREST_CLIENT_ID=
# YOUTUBE_CLIENT_ID=
# TIKTOK_CLIENT_ID=
# LINKEDIN_CLIENT_ID=

# OAuth redirect handled by a local loopback server on a random port.
# OAUTH_REDIRECT_HOST=127.0.0.1
